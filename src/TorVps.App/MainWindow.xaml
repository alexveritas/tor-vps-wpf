<Window
    x:Class="TorVps.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TorVps v0.34"
    Width="444"
    Height="562"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource AppFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border
            Grid.Row="0"
            Background="{StaticResource TitlebarBackgroundBrush}"
            BorderBrush="{StaticResource TitlebarBorderBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <Grid Margin="12,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,7,0" Fill="{StaticResource AccentGreenBrush}" />
                    <TextBlock x:Name="VersionText" Text="Tor-vps v0.34" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource WindowChromeButtonStyle}" Click="Minimize_Click" />
                    <Button Content="✕" Style="{StaticResource WindowChromeButtonStyle}" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar: Main/Conf tabs + Tor/mihomo toggles -->
        <Grid Grid.Row="1" Margin="14,10,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource TabTrackStyle}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Main" Style="{StaticResource MainTabButtonStyle}" Command="{Binding ShowMainTabCommand}" />
                    <Button Style="{StaticResource ConfTabButtonStyle}" Command="{Binding ShowConfTabCommand}">
                        <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}">
                            <Run Text="Conf: " /><Run Text="{Binding ConfTabStatusText, Mode=OneWay}" />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tor:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ToggleButton
                    Style="{StaticResource BinaryToggleStyle}"
                    IsChecked="{Binding TunnelOn, Mode=OneWay}"
                    Command="{Binding ToggleTunnelCommand}"
                    IsEnabled="{Binding TunnelToggleEnabled}"
                    Margin="0,0,12,0" />
                <TextBlock Text="mihomo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ToggleButton
                    Style="{StaticResource BinaryToggleStyle}"
                    IsChecked="{Binding MihomoOn, Mode=OneWay}"
                    Command="{Binding ToggleMihomoCommand}"
                    IsEnabled="{Binding MihomoToggleEnabled}" />
            </StackPanel>
        </Grid>

        <!-- Content: Main or Conf -->
        <Grid Grid.Row="2" Margin="14,0,14,12">

            <!-- Main tab -->
            <Grid Visibility="{Binding IsMainTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0" ItemsSource="{Binding Cards}" Margin="0,0,0,8" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="1" Padding="3,6" CornerRadius="5" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Text}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bandwidth/ping graph: borderless, sits directly on the window background like the reference -->
                <Grid Grid.Row="1" Margin="2,0,2,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource DownSeriesBrush}" Text="{Binding DownCurrentText, Mode=OneWay}" />
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource UpSeriesBrush}" Text="{Binding UpCurrentText, Mode=OneWay}" Margin="0,1,0,0" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource PingSeriesBrush}" HorizontalAlignment="Right" Text="{Binding PingCurrentText, Mode=OneWay}" />
                            <TextBlock FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" Margin="0,1,0,0">
                                <Run Text="peak " /><Run Text="{Binding PingPeakText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <Viewbox Grid.Row="1" Stretch="Fill" Margin="0,4,0,0">
                        <Canvas Width="520" Height="50">
                            <Polygon Points="{Binding UpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                            <Polygon Points="{Binding DownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                            <Polyline Points="{Binding UpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1.3" />
                            <Polyline Points="{Binding DownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1.3" />
                            <Polyline Points="{Binding PingAreaPoints}" Stroke="{StaticResource PingSeriesBrush}" StrokeThickness="1" Opacity="0.85" />
                        </Canvas>
                    </Viewbox>
                </Grid>

                <!-- Lower section: bridges / health / vps / log -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="44" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="130" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding Bridges}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="9" Margin="0,1" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}">
                                        <Run Text="{Binding Index, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Text, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Health}" Focusable="False" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="3" CornerRadius="6" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="8" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Text}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"
                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- VPS: one compact row, like the reference -->
                    <Grid Grid.Row="2" Margin="0,0,0,8" ToolTip="{Binding ServerTooltip}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VPS" FontSize="9" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="9" Foreground="{StaticResource CpuSeriesBrush}">
                                <Run Text="CPU " /><Run Text="{Binding VpsCpuText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" Foreground="{StaticResource MemSeriesBrush}" Margin="8,0,0,0">
                                <Run Text="RAM " /><Run Text="{Binding VpsRamText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" Foreground="{StaticResource DownSeriesBrush}" Margin="8,0,0,0">
                                <Run Text="↓" /><Run Text="{Binding VpsDownCurrentText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" Foreground="{StaticResource UpSeriesBrush}" Margin="8,0,0,0">
                                <Run Text="↑" /><Run Text="{Binding VpsUpCurrentText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Viewbox Grid.Column="2" Stretch="Fill" Height="20">
                            <Canvas Width="260" Height="24">
                                <Polygon Points="{Binding VpsUpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                                <Polygon Points="{Binding VpsDownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                                <Polyline Points="{Binding VpsUpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1" />
                                <Polyline Points="{Binding VpsDownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <ScrollViewer Grid.Row="3" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogLines}" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="9" Foreground="{StaticResource TextDimBrush}" TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Conf tab -->
            <Grid Visibility="{Binding IsConfTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                    <Button Content="проверить файлы конфигурации" Style="{StaticResource ActionButtonStyle}" MinWidth="0"
                            Command="{Binding RecheckConfigCommand}" Margin="0,0,8,0" />
                    <Button Content="Update rules from mihomo.yaml" Style="{StaticResource ActionButtonStyle}" MinWidth="0"
                            Command="{Binding UpdateRulesCommand}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CheckGroups}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorderStyle}" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                                        <ItemsControl ItemsSource="{Binding Items}" Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="10" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="10"
                                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
