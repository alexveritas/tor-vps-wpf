<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="AppFont">Segoe UI Variable Text, Segoe UI</FontFamily>

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0D0D10" Offset="0" />
        <GradientStop Color="#070709" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F5F5F7" />
    </Style>

    <SolidColorBrush x:Key="TitlebarBackgroundBrush" Color="#0F1117" />
    <SolidColorBrush x:Key="TitlebarBorderBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#DC1C1C1E" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#16FFFFFF" />
    <SolidColorBrush x:Key="ChartPanelBackgroundBrush" Color="#FF121216" />
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#FF111114" />
    <SolidColorBrush x:Key="ToggleBorderBrush" Color="#1FFFFFFF" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F5F7" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#A1A1A8" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#9EB4D3" />

    <SolidColorBrush x:Key="AccentGreenBrush" Color="#30D158" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="#FFD60A" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#FF453A" />
    <SolidColorBrush x:Key="AccentGrayBrush" Color="#A1A1A8" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#0A84FF" />
    <SolidColorBrush x:Key="OnDarkTextBrush" Color="#03110A" />

    <SolidColorBrush x:Key="DownSeriesBrush" Color="#74F59A" />
    <SolidColorBrush x:Key="UpSeriesBrush" Color="#40C8FF" />
    <SolidColorBrush x:Key="PingSeriesBrush" Color="#FF6969" />
    <SolidColorBrush x:Key="CpuSeriesBrush" Color="#FFE4C4" />
    <SolidColorBrush x:Key="MemSeriesBrush" Color="#BF5AF2" />

    <LinearGradientBrush x:Key="DownAreaFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5C74F59A" Offset="0" />
        <GradientStop Color="#0074F59A" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UpAreaFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5040C8FF" Offset="0" />
        <GradientStop Color="#0040C8FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Generic rounded panel used for chart/bridge/health/server/log blocks -->
    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="WindowChromeButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#B5C5DF" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- iOS-style sliding pill switch used for the Tor and mihomo toggles -->
    <Style x:Key="BinaryToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="25" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track" Background="{StaticResource ToggleTrackBrush}" BorderBrush="{StaticResource ToggleBorderBrush}" BorderThickness="1" CornerRadius="13">
                        <Grid Margin="2,0">
                            <Ellipse x:Name="Knob" Width="19" Height="19" HorizontalAlignment="Left" Fill="#C7CDD6">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.4" Color="Black" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGreenBrush}" />
                            <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentGreenBrush}" />
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Knob" Property="Fill" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Main/Conf tab strip buttons: transparent by default, sit inside a shared TabTrackStyle border -->
    <Style x:Key="TabButtonBaseStyle" TargetType="Button">
        <Setter Property="Height" Value="26" />
        <Setter Property="MinWidth" Value="56" />
        <Setter Property="Padding" Value="13,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#9AA4B5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="13">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rounded dark track that wraps the Main/Conf buttons into one segmented control -->
    <Style x:Key="TabTrackStyle" TargetType="Border">
        <Setter Property="Background" Value="#FF1B212C" />
        <Setter Property="BorderBrush" Value="#1AFFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Background" Value="{StaticResource AccentGreenBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OnDarkTextBrush}" />
        <Setter Property="MinWidth" Value="210" />
    </Style>

    <SolidColorBrush x:Key="ActiveTabBackgroundBrush" Color="#EDEDF0" />
    <SolidColorBrush x:Key="ActiveTabForegroundBrush" Color="#15151A" />

    <Style x:Key="MainTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMainTab}" Value="True">
                <Setter Property="Background" Value="{StaticResource ActiveTabBackgroundBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ActiveTabForegroundBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ConfTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMainTab}" Value="False">
                <Setter Property="Background" Value="{StaticResource ActiveTabBackgroundBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ActiveTabForegroundBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Thin, near-invisible scrollbar matching the reference's minimal chrome -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb>
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="#33FFFFFF" CornerRadius="3" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Opacity="0" Focusable="False" Command="ScrollBar.PageUpCommand" />
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Opacity="0" Focusable="False" Command="ScrollBar.PageDownCommand" />
                        </Track.IncreaseRepeatButton>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
