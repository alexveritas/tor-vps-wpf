<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!--  DESIGN TOKENS  (iOS-12 Dark)                                  -->
    <!--  Single source of truth for the whole skin. Components below   -->
    <!--  reference these; views should not hard-code colors/sizes.     -->
    <!-- ============================================================= -->

    <FontFamily x:Key="AppFont">Segoe UI Variable Text, Segoe UI</FontFamily>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusLarge">14</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">10</CornerRadius>
    <CornerRadius x:Key="RadiusSmall">7</CornerRadius>
    <CornerRadius x:Key="RadiusPill">13</CornerRadius>

    <!-- Surfaces -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0C0C0F" Offset="0" />
        <GradientStop Color="#050506" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="TitlebarBackgroundBrush" Color="#0E0E11" />
    <SolidColorBrush x:Key="TitlebarBorderBrush" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1C1C1E" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#2C2C2E" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#D81C1C1E" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#1FFFFFFF" />
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#39393D" />
    <SolidColorBrush x:Key="TabTrackBrush" Color="#16161A" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F5F7" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8E8E93" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#9EB4D3" />

    <!-- Accents (iOS-12 dark system colors) -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#30D158" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="#FFD60A" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#FF453A" />
    <SolidColorBrush x:Key="AccentGrayBrush" Color="#8E8E93" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#0A84FF" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF9F0A" />
    <SolidColorBrush x:Key="OnDarkTextBrush" Color="#03110A" />
    <SolidColorBrush x:Key="ActiveTabBackgroundBrush" Color="#3A3A3C" />
    <SolidColorBrush x:Key="ActiveTabForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ActiveTabBorderBrush" Color="#5C5C60" />
    <SolidColorBrush x:Key="InactiveTabForegroundBrush" Color="#C7C7CC" />

    <!-- Graph series -->
    <SolidColorBrush x:Key="DownSeriesBrush" Color="#74F59A" />
    <SolidColorBrush x:Key="UpSeriesBrush" Color="#40C8FF" />
    <SolidColorBrush x:Key="PingSeriesBrush" Color="#FF6969" />
    <SolidColorBrush x:Key="CpuSeriesBrush" Color="#FFE4C4" />
    <SolidColorBrush x:Key="MemSeriesBrush" Color="#BF5AF2" />
    <SolidColorBrush x:Key="GraphGridBrush" Color="#202B3B" />

    <LinearGradientBrush x:Key="DownAreaFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5C34C759" Offset="0" />
        <GradientStop Color="#0034C759" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="UpAreaFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5040C8FF" Offset="0" />
        <GradientStop Color="#0040C8FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PingAreaFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4DFF6969" Offset="0" />
        <GradientStop Color="#00FF6969" Offset="1" />
    </LinearGradientBrush>

    <!-- ============================================================= -->
    <!--  COMPONENT SKINS                                               -->
    <!-- ============================================================= -->

    <!-- Default text -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- Window min/close chrome buttons -->
    <Style x:Key="WindowChromeButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#B5C5DF" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Segmented control (Main/Conf): a dark rounded track wrapping the buttons -->
    <Style x:Key="TabTrackStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TabTrackBrush}" />
        <Setter Property="BorderBrush" Value="#14FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
        <Setter Property="Padding" Value="2" />
    </Style>

    <Style x:Key="TabButtonBaseStyle" TargetType="Button">
        <Setter Property="Height" Value="26" />
        <Setter Property="MinWidth" Value="58" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource InactiveTabForegroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="11">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MainTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMainTab}" Value="True">
                <Setter Property="Background" Value="{StaticResource ActiveTabBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ActiveTabBorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ActiveTabForegroundBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ConfTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMainTab}" Value="False">
                <Setter Property="Background" Value="{StaticResource ActiveTabBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ActiveTabBorderBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ActiveTabForegroundBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- iOS sliding switch (Tor / mihomo) -->
    <Style x:Key="BinaryToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track" Background="{StaticResource ToggleTrackBrush}" CornerRadius="13">
                        <Grid Margin="1,0">
                            <Ellipse x:Name="Knob" Width="24" Height="24" HorizontalAlignment="Left" Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.35" Color="Black" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGreenBrush}" />
                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rounded elevated panel/card -->
    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
    </Style>

    <!-- Status card tile (5-card row) -->
    <Style x:Key="StatusCardBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Padding" Value="4,6" />
    </Style>

    <!-- Health chip tile -->
    <Style x:Key="HealthChipBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <!-- Filled (green) pill action button -->
    <Style x:Key="ActionButtonFilledStyle" TargetType="Button">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource OnDarkTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="{StaticResource RadiusSmall}" Padding="{TemplateBinding Padding}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#39DF67" Offset="0" />
                                <GradientStop Color="#30D158" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost (outline) action button -->
    <Style x:Key="ActionButtonGhostStyle" TargetType="Button">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="{StaticResource RadiusSmall}" Background="#142A8DFF"
                            BorderBrush="#552A8DFF" BorderThickness="1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#242A8DFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thin minimal scrollbar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb>
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="#2EFFFFFF" CornerRadius="2" />
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Opacity="0" Focusable="False" Command="ScrollBar.PageUpCommand" />
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Opacity="0" Focusable="False" Command="ScrollBar.PageDownCommand" />
                        </Track.IncreaseRepeatButton>
                    </Track>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
