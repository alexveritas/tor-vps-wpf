root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4

[*.{csproj,props,targets,sln}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2
end_of_line = lf

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
