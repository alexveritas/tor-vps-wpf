<Window
    x:Class="TorVps.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TorVps"
    Width="444"
    Height="580"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource AppFont}"
    TextOptions.TextFormattingMode="Ideal">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border
            Grid.Row="0"
            Background="{StaticResource TitlebarBackgroundBrush}"
            BorderBrush="{StaticResource TitlebarBorderBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <Grid Margin="12,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,7,0" Fill="{StaticResource AccentGreenBrush}" />
                    <TextBlock x:Name="VersionText" Text="Tor-vps" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource WindowChromeButtonStyle}" Click="Minimize_Click" />
                    <Button Content="✕" Style="{StaticResource WindowChromeButtonStyle}" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar: segmented Main/Conf + Tor/mihomo toggles -->
        <Grid Grid.Row="1" Margin="14,10,14,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource TabTrackStyle}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Main" Style="{StaticResource MainTabButtonStyle}" Command="{Binding ShowMainTabCommand}" />
                    <Button Style="{StaticResource ConfTabButtonStyle}" Command="{Binding ShowConfTabCommand}">
                        <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}">
                            <Run Text="Conf: " /><Run Text="{Binding ConfTabStatusText, Mode=OneWay}" />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tor:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ToggleButton
                    Style="{StaticResource BinaryToggleStyle}"
                    IsChecked="{Binding TunnelOn, Mode=OneWay}"
                    Command="{Binding ToggleTunnelCommand}"
                    IsEnabled="{Binding TunnelToggleEnabled}"
                    Margin="0,0,12,0" />
                <TextBlock Text="mihomo:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ToggleButton
                    Style="{StaticResource BinaryToggleStyle}"
                    IsChecked="{Binding MihomoOn, Mode=OneWay}"
                    Command="{Binding ToggleMihomoCommand}"
                    IsEnabled="{Binding MihomoToggleEnabled}" />
            </StackPanel>
        </Grid>

        <!-- Content: Main or Conf -->
        <Grid Grid.Row="2" Margin="14,0,14,12">

            <!-- ===================== MAIN TAB ===================== -->
            <Grid Visibility="{Binding IsMainTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 5 status cards -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding Cards}" Margin="0,0,0,8" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusCardBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bandwidth/ping graph: chart with overlaid max/cur/avg labels (speed left, ping right) -->
                <Grid Grid.Row="1" Height="76" Margin="2,0,2,8">
                    <Viewbox Stretch="Fill">
                        <Canvas Width="520" Height="50" Background="Transparent">
                            <Polygon Points="{Binding DownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                            <Polygon Points="{Binding UpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                            <Polygon Points="{Binding PingFillPoints}" Fill="{StaticResource PingAreaFillBrush}" />
                            <Polyline Points="{Binding DownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1.2" />
                            <Polyline Points="{Binding UpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1.2" />
                            <Polyline Points="{Binding PingAreaPoints}" Stroke="{StaticResource PingSeriesBrush}" StrokeThickness="1" />
                        </Canvas>
                    </Viewbox>
                    <!-- Speed labels: max / cur / avg (↓ down, ↑ up) -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1,1,0,0">
                        <TextBlock FontSize="9" FontWeight="SemiBold">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownPeakText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpPeakText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="9" FontWeight="SemiBold">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownCurrentText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpCurrentText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="9" FontWeight="SemiBold">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownAverageText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpAverageText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Ping labels: max / cur / avg -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,1,0">
                        <TextBlock FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingPeakText, Mode=OneWay}" />
                        <TextBlock FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingCurrentText, Mode=OneWay}" />
                        <TextBlock FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingAverageText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <!-- Lower section: bridges / health / vps / log -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="44" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="128" />
                    </Grid.RowDefinitions>

                    <!-- Bridges: two numbered columns -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding Bridges}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="9" Margin="0,1" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}">
                                        <Run Foreground="{StaticResource TextMutedBrush}" Text="{Binding Index, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Text, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Health chips (4 per row) -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Health}" Focusable="False" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource HealthChipBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Text}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,1,0,0"
                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- VPS compact metrics row + sparkline -->
                    <Grid Grid.Row="2" Margin="0,0,0,8" ToolTip="{Binding ServerTooltip}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="124" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VPS" FontSize="9" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource CpuSeriesBrush}">
                                <Run Text="CPU " /><Run Text="{Binding VpsCpuText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource MemSeriesBrush}" Margin="10,0,0,0">
                                <Run Text="RAM " /><Run Text="{Binding VpsRamText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" Margin="10,0,0,0">
                                <Run Text="↓" /><Run Text="{Binding VpsDownCurrentText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" Margin="8,0,0,0">
                                <Run Text="↑" /><Run Text="{Binding VpsUpCurrentText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Viewbox Grid.Column="3" Stretch="Fill" Height="22">
                            <Canvas Width="260" Height="24" Background="Transparent">
                                <Polygon Points="{Binding VpsUpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                                <Polygon Points="{Binding VpsDownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                                <Polyline Points="{Binding VpsUpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1" />
                                <Polyline Points="{Binding VpsDownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <!-- Runtime log -->
                    <Border Grid.Row="3" Style="{StaticResource PanelBorderStyle}" Padding="8,5">
                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LogLines}" Focusable="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="9" Foreground="{StaticResource TextDimBrush}" TextWrapping="NoWrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===================== CONF TAB ===================== -->
            <Grid Visibility="{Binding IsConfTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                    <Button Content="проверить файлы конфигурации" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding RecheckConfigCommand}" Margin="0,0,8,0" />
                    <Button Content="Update rules from mihomo.yaml" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding UpdateRulesCommand}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CheckGroups}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorderStyle}" Padding="12,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                                        <ItemsControl ItemsSource="{Binding Items}" Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="10" TextAlignment="Right" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
