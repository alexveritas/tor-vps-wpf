<Window
    x:Class="TorVps.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tor-xray-tun"
    Icon="tor_onion.ico"
    Width="452"
    Height="568"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource AppFont}"
    TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="26" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border
            Grid.Row="0"
            Background="{StaticResource TitlebarBackgroundBrush}"
            BorderBrush="{StaticResource TitlebarBorderBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <Grid Margin="12,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,8,0" Fill="{StaticResource AccentGreenBrush}" />
                    <TextBlock x:Name="VersionText" Text="Tor-xray-tun" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource WindowChromeButtonStyle}" Click="Minimize_Click" />
                    <Button Content="✕" Style="{StaticResource WindowChromeButtonStyle}" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Graphic's / Tor / mihomo toggles: top block, above the Main/Conf tabs; right-aligned -->
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Height="38" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="Graphic's:" FontSize="11" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ToggleButton Style="{StaticResource BinaryToggleStyle}" IsChecked="{Binding GraphicsOn}" />
                <TextBlock Text="Tor:" FontSize="11" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="14,0,6,0" />
                <ToggleButton Style="{StaticResource BinaryToggleStyle}" IsChecked="{Binding TunnelOn, Mode=OneWay}" Command="{Binding ToggleTunnelCommand}" IsEnabled="{Binding TunnelToggleEnabled}" />
                <TextBlock Text="mihomo:" FontSize="11" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="14,0,6,0" />
                <ToggleButton Style="{StaticResource BinaryToggleStyle}" IsChecked="{Binding MihomoOn, Mode=OneWay}" Command="{Binding ToggleMihomoCommand}" IsEnabled="{Binding MihomoToggleEnabled}" />
                <TextBlock Text="VPS-tunnel:" FontSize="11" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="14,0,6,0" />
                <ToggleButton Style="{StaticResource BinaryToggleStyle}" IsChecked="{Binding VpsTunnelOn, Mode=OneWay}" Command="{Binding ToggleVpsTunnelCommand}" IsEnabled="{Binding VpsTunnelToggleEnabled}" />
            </StackPanel>
        </Border>

        <!-- Toolbar: TabView tabs (Main/Conf) joined to a separator line -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Border VerticalAlignment="Bottom" Height="1" Margin="-4,0,-4,0" Background="{StaticResource TabSeparatorBrush}" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Content="Main" Style="{StaticResource MainTabButtonStyle}" Command="{Binding ShowMainTabCommand}" Margin="0,0,4,0" />
                <Button Content="Bridges" Style="{StaticResource BridgesTabButtonStyle}" Command="{Binding ShowBridgesTabCommand}" Margin="0,0,4,0" />
                <Button Style="{StaticResource ConfigTabButtonStyle}" Command="{Binding ShowConfigTabCommand}">
                    <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}">
                        <Run Text="Config files: " /><Run Text="{Binding ConfTabStatusText, Mode=OneWay}" />
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content: Main or Conf -->
        <Grid Grid.Row="3" Margin="0,4,0,0">

            <!-- ===================== MAIN TAB ===================== -->
            <Grid Visibility="{Binding IsMainTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                    <RowDefinition Height="85" />
                </Grid.RowDefinitions>

                <!-- 1. status cards -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding Cards}" Margin="0,0,0,4" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusCardBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="10" Foreground="{StaticResource LabelBrightBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Text}" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 2. Health chips (4 per row) -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Health}" Focusable="False" Margin="0,0,0,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource HealthChipBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}" FontSize="9" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" />
                                    <!-- Plain value (hidden when a colored breakdown is present, e.g. the Bridges chip) -->
                                    <TextBlock Text="{Binding Text}" FontSize="9" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Segments, Converter={StaticResource NullToVisibilityConverter}}"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                    <!-- Colored green/yellow/red breakdown (bridge availability) -->
                                    <ItemsControl ItemsSource="{Binding Segments}" Margin="4,0,0,0" VerticalAlignment="Center" Focusable="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}" FontSize="9" Margin="0,0,3,0" VerticalAlignment="Center"
                                                           Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 3. Bandwidth/ping graph: cropped to just fit the 3 value rows (down/up/ping).
                       Shown only while "Graphic's:" is ON (otherwise the big VPS block below replaces both graphs). -->
                <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Height="48" Margin="0,0,0,4" Padding="6,3"
                        Visibility="{Binding GraphicsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Viewbox Stretch="Fill">
                            <Canvas Width="520" Height="50" Background="Transparent" ClipToBounds="True">
                                <Polygon Points="{Binding DownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                                <Polygon Points="{Binding UpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                                <Polygon Points="{Binding PingFillPoints}" Fill="{StaticResource PingAreaFillBrush}" />
                                <Polyline Points="{Binding DownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1.2" />
                                <Polyline Points="{Binding UpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1.2" />
                                <Polyline Points="{Binding PingAreaPoints}" Stroke="{StaticResource PingSeriesBrush}" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                        <!-- Speed labels: max / cur / avg (↓ down, ↑ up), each on a translucent chip -->
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Left">
                                <TextBlock FontSize="9">
                                    <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownPeakText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpPeakText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Left" Margin="0,2,0,0">
                                <TextBlock FontSize="9">
                                    <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownCurrentText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpCurrentText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Left" Margin="0,2,0,0">
                                <TextBlock FontSize="9">
                                    <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownAverageText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpAverageText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <!-- Ping labels: max / cur / avg, each on a translucent chip -->
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Right">
                                <TextBlock FontSize="9" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingPeakText, Mode=OneWay}" />
                            </Border>
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Right" Margin="0,2,0,0">
                                <TextBlock FontSize="9" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingCurrentText, Mode=OneWay}" />
                            </Border>
                            <Border Style="{StaticResource GraphValueChipStyle}" HorizontalAlignment="Right" Margin="0,2,0,0">
                                <TextBlock FontSize="9" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingAverageText, Mode=OneWay}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 4. VPS metrics table (2 rows) + sparkline, mirroring the reference ServerGraphPanel:
                       VPS  CPU: {cpu}%   {downCur} ↓ {downPeak}
                            RAM: {ram}%   {upCur}   ↑ {upPeak}   | graph fills the rest -->
                <Border Grid.Row="3" Style="{StaticResource PanelBorderStyle}" Height="44" Margin="0,0,0,4" Padding="8,4"
                        Visibility="{Binding GraphicsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Aligned metrics table: label | %value | current | arrow | peak -->
                        <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="17" />
                                <RowDefinition Height="17" />
                            </Grid.RowDefinitions>

                            <!-- VPS panel label (top-left cell) -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VPS" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" />

                            <!-- Row 1: CPU + download current/peak -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="CPU:" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource CpuSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding VpsCpuText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource CpuSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding VpsDownCurrentText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="↓" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding VpsDownPeakText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />

                            <!-- Row 2: RAM + upload current/peak -->
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="RAM:" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource MemSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding VpsRamText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource MemSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding VpsUpCurrentText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="↑" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="6" Text="{Binding VpsUpPeakText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Sparkline fills the remaining width (Canvas height stays 24 = VpsGraphLogicalHeight) -->
                        <Viewbox Grid.Column="1" Stretch="Fill" Height="32" VerticalAlignment="Center">
                            <Canvas Width="260" Height="24" Background="Transparent" ClipToBounds="True">
                                <Polygon Points="{Binding VpsDownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                                <Polygon Points="{Binding VpsUpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                                <Polyline Points="{Binding VpsDownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1" />
                                <Polyline Points="{Binding VpsUpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- 3+4 ("Graphic's:" OFF): one block in place of both graphs — the same VPS numbers
                       (CPU / RAM / net current+peak), scaled up to fill the whole block height. -->
                <Border Grid.Row="2" Grid.RowSpan="2" Style="{StaticResource PanelBorderStyle}" Height="96" Margin="0,0,0,4" Padding="12,8"
                        Visibility="{Binding GraphicsOn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Viewbox Stretch="Uniform">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="17" />
                                <RowDefinition Height="17" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VPS" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" />

                            <!-- Row 1: CPU + download current/peak -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="CPU:" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource CpuSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding VpsCpuText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource CpuSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding VpsDownCurrentText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="↓" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding VpsDownPeakText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource DownSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />

                            <!-- Row 2: RAM + upload current/peak -->
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="RAM:" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource MemSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding VpsRamText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource MemSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding VpsUpCurrentText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="5" Text="↑" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="6" Text="{Binding VpsUpPeakText, Mode=OneWay}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource UpSeriesBrush}" TextAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Viewbox>
                </Border>

                <!-- 5. Placeholder (reserved for future content) -->
                <Border Grid.Row="4" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,4" />

                <!-- 6. Runtime log: fixed 5-line viewport (15px line-height) so whole lines always show -->
                <Border Grid.Row="5" Style="{StaticResource PanelBorderStyle}" Padding="6,4,0,4">
                    <ScrollViewer x:Name="LogScrollViewer" Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LogLines}" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Colored by severity: dim = normal, yellow = warning, red = error -->
                                    <TextBlock Text="{Binding}" FontSize="9.5" LineHeight="15" LineStackingStrategy="BlockLineHeight"
                                               Foreground="{Binding Converter={StaticResource LogLineToForegroundBrushConverter}}" TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ===================== BRIDGES TAB ===================== -->
            <Grid Visibility="{Binding IsBridgesTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Availability summary accumulated while Tor is healthy + reload from file -->
                <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="8,5" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Availability" FontSize="10" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0">
                                <Run Text="●" Foreground="#30D158" /><Run Text=" " /><Run Text="{Binding BridgeGreenCount, Mode=OneWay}" Foreground="#30D158" /><Run Text=" always" Foreground="{StaticResource TextDimBrush}" />
                            </TextBlock>
                            <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0">
                                <Run Text="●" Foreground="#FFD60A" /><Run Text=" " /><Run Text="{Binding BridgeYellowCount, Mode=OneWay}" Foreground="#FFD60A" /><Run Text=" flaky" Foreground="{StaticResource TextDimBrush}" />
                            </TextBlock>
                            <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0">
                                <Run Text="●" Foreground="#FF453A" /><Run Text=" " /><Run Text="{Binding BridgeRedCount, Mode=OneWay}" Foreground="#FF453A" /><Run Text=" down" Foreground="{StaticResource TextDimBrush}" />
                            </TextBlock>
                            <TextBlock FontSize="10" VerticalAlignment="Center">
                                <Run Text="●" Foreground="#A1A1A8" /><Run Text=" " /><Run Text="{Binding BridgeGrayCount, Mode=OneWay}" Foreground="#A1A1A8" /><Run Text=" unused" Foreground="{StaticResource TextDimBrush}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Reload from bridges.txt" Style="{StaticResource ActionButtonFilledStyle}"
                                Height="22" Padding="10,0" FontSize="10" VerticalAlignment="Center"
                                Command="{Binding ReloadBridgesCommand}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="6,4,0,4">
                    <ScrollViewer Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Bridges}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="9.5" Margin="0,1,12,1" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}">
                                        <Run Foreground="{StaticResource TextMutedBrush}" Text="{Binding Index, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Text, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ===================== CONFIG FILES TAB ===================== -->
            <Grid Visibility="{Binding IsConfigTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,10">
                    <!-- Configs are validated automatically on every (re)load; this forces an immediate re-read
                         so cfg edits apply without restarting the app. -->
                    <Button Content="Reload all conf" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding ReloadConfigCommand}" Margin="0,0,8,0" />
                    <Button Content="Update rules from mihomo.yaml" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding UpdateRulesCommand}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CheckGroups}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorderStyle}" Padding="12,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10" Foreground="{StaticResource LabelBrightBrush}" Margin="0,0,0,6" />
                                        <ItemsControl ItemsSource="{Binding Items}" Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="10" TextAlignment="Right" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
