<Window
    x:Class="TorVps.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TorVps"
    Width="452"
    Height="568"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource AppFont}"
    TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="26" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border
            Grid.Row="0"
            Background="{StaticResource TitlebarBackgroundBrush}"
            BorderBrush="{StaticResource TitlebarBorderBrush}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <Grid Margin="12,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,8,0" Fill="{StaticResource AccentGreenBrush}" />
                    <TextBlock x:Name="VersionText" Text="Tor-vps" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource WindowChromeButtonStyle}" Click="Minimize_Click" />
                    <Button Content="✕" Style="{StaticResource WindowChromeButtonStyle}" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar: TabView tabs (Main/Conf) joined to a separator line + Tor/mihomo toggles -->
        <Grid Grid.Row="1">
            <Border VerticalAlignment="Bottom" Height="1" Margin="-4,0,-4,0" Background="{StaticResource TabSeparatorBrush}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Main" Style="{StaticResource MainTabButtonStyle}" Command="{Binding ShowMainTabCommand}" Margin="0,0,4,0" />
                    <Button Style="{StaticResource ConfTabButtonStyle}" Command="{Binding ShowConfTabCommand}">
                        <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}">
                            <Run Text="Conf: " /><Run Text="{Binding ConfTabStatusText, Mode=OneWay}" />
                        </TextBlock>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="Tor:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <ToggleButton
                        Style="{StaticResource BinaryToggleStyle}"
                        IsChecked="{Binding TunnelOn, Mode=OneWay}"
                        Command="{Binding ToggleTunnelCommand}"
                        IsEnabled="{Binding TunnelToggleEnabled}"
                        Margin="0,0,12,0" />
                    <TextBlock Text="mihomo:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <ToggleButton
                        Style="{StaticResource BinaryToggleStyle}"
                        IsChecked="{Binding MihomoOn, Mode=OneWay}"
                        Command="{Binding ToggleMihomoCommand}"
                        IsEnabled="{Binding MihomoToggleEnabled}" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Content: Main or Conf -->
        <Grid Grid.Row="2" Margin="0,4,0,0">

            <!-- ===================== MAIN TAB ===================== -->
            <Grid Visibility="{Binding IsMainTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 5 status cards (84x40) -->
                <ItemsControl Grid.Row="0" ItemsSource="{Binding Cards}" Margin="0,0,0,4" Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusCardBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource LabelBrightBrush}" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Text}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bandwidth/ping graph (72px), framed like the log block -->
                <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Height="72" Margin="0,0,0,4" Padding="6,3">
                    <Grid>
                    <Viewbox Stretch="Fill">
                        <Canvas Width="520" Height="50" Background="Transparent" ClipToBounds="True">
                            <Polygon Points="{Binding DownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                            <Polygon Points="{Binding UpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                            <Polygon Points="{Binding PingFillPoints}" Fill="{StaticResource PingAreaFillBrush}" />
                            <Polyline Points="{Binding DownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1.2" />
                            <Polyline Points="{Binding UpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1.2" />
                            <Polyline Points="{Binding PingAreaPoints}" Stroke="{StaticResource PingSeriesBrush}" StrokeThickness="1" />
                        </Canvas>
                    </Viewbox>
                    <!-- Speed labels: max / cur / avg (↓ down, ↑ up) -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                        <TextBlock FontSize="9" FontWeight="Bold">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownPeakText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpPeakText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="9" FontWeight="Bold" Margin="0,2,0,0">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownCurrentText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpCurrentText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="9" FontWeight="Bold" Margin="0,2,0,0">
                            <Run Foreground="#74F59A" Text="↓" /><Run Foreground="#74F59A" Text="{Binding DownAverageText, Mode=OneWay}" /><Run Text="  " /><Run Foreground="#40C8FF" Text="↑" /><Run Foreground="#40C8FF" Text="{Binding UpAverageText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <!-- Ping labels: max / cur / avg -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                        <TextBlock FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingPeakText, Mode=OneWay}" />
                        <TextBlock FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingCurrentText, Mode=OneWay}" />
                        <TextBlock FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0" Foreground="{StaticResource PingSeriesBrush}" Text="{Binding PingAverageText, Mode=OneWay}" />
                    </StackPanel>
                    </Grid>
                </Border>

                <!-- Lower section: bridges (*) / health (52) / vps (44) / log (5 lines) -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="52" />
                        <RowDefinition Height="44" />
                        <RowDefinition Height="85" />
                    </Grid.RowDefinitions>

                    <!-- Bridges: two numbered columns, framed like the log block (scrollbar gutter flush to right edge) -->
                    <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,4" Padding="6,4,0,4">
                        <ScrollViewer Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Bridges}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="9" FontWeight="SemiBold" Margin="0,1" TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}">
                                        <Run Foreground="{StaticResource TextMutedBrush}" Text="{Binding Index, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Text, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Health chips (4 per row, 20px tall) -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Health}" Focusable="False" Margin="0,0,0,4" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource HealthChipBorderStyle}" Background="{Binding State, Converter={StaticResource HealthStateToBackgroundBrushConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Text}" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- VPS compact metrics row + sparkline, framed like the log block -->
                    <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,4" Padding="8,2" ToolTip="{Binding ServerTooltip}">
                        <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VPS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource LabelBrightBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource CpuSeriesBrush}">
                                <Run Text="CPU " /><Run Text="{Binding VpsCpuText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource MemSeriesBrush}" Margin="10,0,0,0">
                                <Run Text="RAM " /><Run Text="{Binding VpsRamText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource DownSeriesBrush}" Margin="10,0,0,0">
                                <Run Text="↓" /><Run Text="{Binding VpsDownCurrentText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource UpSeriesBrush}" Margin="8,0,0,0">
                                <Run Text="↑" /><Run Text="{Binding VpsUpCurrentText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Viewbox Grid.Column="3" Stretch="Fill" Height="24">
                            <Canvas Width="260" Height="24" Background="Transparent" ClipToBounds="True">
                                <Polygon Points="{Binding VpsDownFillPoints}" Fill="{StaticResource DownAreaFillBrush}" />
                                <Polygon Points="{Binding VpsUpFillPoints}" Fill="{StaticResource UpAreaFillBrush}" />
                                <Polyline Points="{Binding VpsDownAreaPoints}" Stroke="{StaticResource DownSeriesBrush}" StrokeThickness="1" />
                                <Polyline Points="{Binding VpsUpAreaPoints}" Stroke="{StaticResource UpSeriesBrush}" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Runtime log: fixed 5-line viewport (15px line-height) so whole lines always show -->
                    <Border Grid.Row="3" Style="{StaticResource PanelBorderStyle}" Padding="6,4,0,4">
                        <ScrollViewer x:Name="LogScrollViewer" Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LogLines}" Focusable="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="9.5" LineHeight="15" LineStackingStrategy="BlockLineHeight"
                                                   Foreground="{StaticResource TextDimBrush}" TextWrapping="NoWrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===================== CONF TAB ===================== -->
            <Grid Visibility="{Binding IsConfTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,10">
                    <Button Content="проверить файлы конфигурации" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding RecheckConfigCommand}" Margin="0,0,8,0" />
                    <Button Content="Update rules from mihomo.yaml" Style="{StaticResource ActionButtonFilledStyle}"
                            Command="{Binding UpdateRulesCommand}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScrollViewerStyle}" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CheckGroups}" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorderStyle}" Padding="12,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource LabelBrightBrush}" Margin="0,0,0,6" />
                                        <ItemsControl ItemsSource="{Binding Items}" Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Detail}" FontSize="10" TextAlignment="Right" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding State, Converter={StaticResource HealthStateToForegroundBrushConverter}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
